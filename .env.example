# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Africa's Talking SMS (serverless api/send-sms.js)
AT_API_KEY=
AT_USERNAME=sandbox
# Production: https://api.africastalking.com/version1/messaging
# AT_MESSAGING_URL=https://api.africastalking.com/version1/messaging
# AT_SENDER_ID=SplashPass

# Admin 2FA email codes (Resend) — required for admin login + `next build`
RESEND_API_KEY=

# M-Pesa Daraja (serverless api/mpesa-stk.js) — required
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Optional: sandbox defaults below are used when unset. Set MPESA_PASSKEY for production.
# MPESA_PASSKEY=
# MPESA_SHORTCODE=174379
# MPESA_BASE_URL=https://sandbox.safaricom.co.ke
# MPESA_CALLBACK_URL=https://splashmain.vercel.app/api/mpesa-callback
# api/mpesa-callback.js reuses NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY

# Sessions (required in production; min 32 chars)
SESSION_SECRET=

# Subdomain routing (production)
NEXT_PUBLIC_ROOT_DOMAIN=splashpass.site

# Local dev: simulate operator or admin on localhost (optional)
# DEV_SITE=customer
# DEV_SITE=operator
# DEV_SITE=admin

# Or send header: x-splashpass-site: operator
