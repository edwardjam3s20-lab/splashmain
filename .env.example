# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Africa's Talking SMS (serverless api/send-sms.js)
AT_API_KEY=
AT_USERNAME=sandbox
# Production: https://api.africastalking.com/version1/messaging
# AT_MESSAGING_URL=https://api.africastalking.com/version1/messaging
# AT_SENDER_ID=SplashPass

# Sessions (required in production; min 32 chars)
SESSION_SECRET=

# The customer app's real deployed origin. Used for CORS on the
# customer-facing routes that are called cross-origin from the browser
# (api/bookings, api/customer/profile, api/customer/bookings) — previously
# these sent `Access-Control-Allow-Origin: *` with no session check at all.
# Falls back to https://splashpass-react-poc.vercel.app if unset.
CUSTOMER_APP_ORIGIN=

# Optional but recommended: a random secret checked against a `?token=`
# query param on the M-Pesa callback URL, since Daraja doesn't sign its
# callbacks. Set MPESA_CALLBACK_URL (in the customer app's env) to include
# "?token=<this same value>", e.g.
#   https://splashmain.vercel.app/api/mpesa-callback?token=<value>
# Generate one with: openssl rand -hex 24
MPESA_CALLBACK_SECRET=

# M-Pesa Daraja B2C operator payouts
# Use sandbox until your Daraja app is approved for live B2C.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_B2C_SHORTCODE=
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
# Optional. Defaults to https://<request-host>/api/mpesa/b2c/result and /timeout.
# MPESA_B2C_RESULT_URL=
# MPESA_B2C_TIMEOUT_URL=
# MPESA_B2C_COMMAND_ID=BusinessPayment

# Subdomain routing (production)
NEXT_PUBLIC_ROOT_DOMAIN=splashpass.site

# Local dev: simulate operator or admin on localhost (optional)
# DEV_SITE=customer
# DEV_SITE=operator
# DEV_SITE=admin

# Or send header: x-splashpass-site: operator
